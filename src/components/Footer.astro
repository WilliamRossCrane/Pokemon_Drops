---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-white/[0.08] bg-gradient-to-t from-white/[0.02] to-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 mb-10">

      <div>
        <h3 class="font-display font-bold text-white text-sm mb-4">TCGDrop GC</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          A community-made tracker for Gold Coast Pokémon TCG collectors. Not affiliated
          with Nintendo, Creatures, or The Pokémon Company.
        </p>
      </div>

      <div>
        <h3 class="font-display font-bold text-white text-sm mb-4">Pages</h3>
        <ul class="space-y-2.5">
          {[
            ["/", "Home"],
            ["/releases", "All Releases"],
            ["/stores", "Stores"],
            ["/about", "About & Data"],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-gray-200 text-sm transition-colors duration-150">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-display font-bold text-white text-sm mb-4">Disclaimer</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Release dates and preorder windows change frequently. Stock is never guaranteed.
          Always verify with retailers. Source links are provided for all releases.
        </p>
      </div>
    </div>

    <div class="border-t border-white/[0.08] pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-xs">
        &copy; {year} TCGDrop GC — Community project for Gold Coast, QLD, Australia.
      </p>
      <p class="text-gray-600 text-xs">
        Built with <a href="https://astro.build" class="text-gray-400 hover:text-gray-300 transition-colors">Astro</a> ·
        Data via GitHub Actions
      </p>
    </div>
  </div>
</footer>
