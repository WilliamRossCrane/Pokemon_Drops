---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-white/[0.06] bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">

      <div>
        <h3 class="font-display font-bold text-white text-sm mb-3">TCGDrop GC</h3>
        <p class="text-gray-500 text-xs leading-relaxed">
          A fan-made tracker for Gold Coast Pokémon TCG collectors. Not affiliated
          with Nintendo, Creatures, or The Pokémon Company.
        </p>
      </div>

      <div>
        <h3 class="font-display font-bold text-white text-sm mb-3">Pages</h3>
        <ul class="space-y-2">
          {[
            ["/", "Home"],
            ["/releases", "All Releases"],
            ["/stores", "Stores"],
            ["/about", "About & Data"],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="text-gray-500 hover:text-gray-300 text-xs transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-display font-bold text-white text-sm mb-3">Disclaimer</h3>
        <p class="text-gray-500 text-xs leading-relaxed">
          Release dates and preorder windows can change. Stock is never guaranteed.
          Always verify with the retailer directly. Source links are shown for every release.
        </p>
      </div>
    </div>

    <div class="border-t border-white/[0.06] pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-gray-600 text-xs">
        &copy; {year} TCGDrop GC — Fan project, Gold Coast QLD, Australia.
      </p>
      <p class="text-gray-700 text-xs">
        Built with <a href="https://astro.build" class="hover:text-gray-500 transition-colors">Astro</a> ·
        Data updated by GitHub Actions
      </p>
    </div>
  </div>
</footer>
