---
import type { Likelihood } from "../types/release";
interface Props {
  likelihood: Likelihood;
}
const { likelihood } = Astro.props;

const styleMap: Record<Likelihood, string> = {
  very_likely: "likelihood-very_likely",
  likely: "likelihood-likely",
  possible: "likelihood-possible",
  unclear: "likelihood-unclear",
};
const labelMap: Record<Likelihood, string> = {
  very_likely: "Very likely",
  likely: "Likely",
  possible: "Possible",
  unclear: "Unclear",
};
---
<span class={`badge ${styleMap[likelihood]}`}>
  {labelMap[likelihood]}
</span>
