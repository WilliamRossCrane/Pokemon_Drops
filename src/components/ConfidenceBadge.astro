---
import type { Confidence } from "../types/release";

interface Props {
  confidence: Confidence;
}
const { confidence } = Astro.props;

const colorMap: Record<Confidence, string> = {
  high: "confidence-high",
  medium: "confidence-medium",
  low: "confidence-low",
};

const labels: Record<Confidence, string> = {
  high: "High",
  medium: "Medium",
  low: "Low",
};

const icons: Record<Confidence, string> = {
  high: "●",
  medium: "◐",
  low: "◯",
};
---

<span
  class={`badge ${colorMap[confidence]}`}
  title="Confidence in this release date"
>
  <span aria-hidden="true" class="mr-1 text-sm">{icons[confidence]}</span>
  {labels[confidence]}
</span>
