---
import type { Store } from "../types/store";
import { STORE_TYPE_LABELS } from "../types/store";

interface Props {
  store: Store;
}

const { store } = Astro.props;
---

<div class="pocket-card p-6 flex flex-col">
  <!-- Header row -->
  <div class="mb-4">
    <h3 class="font-display font-bold text-white text-lg leading-snug">
      {store.name}
    </h3>
    {store.suburb && (
      <p class="text-gray-400 text-sm mt-1">{store.suburb}</p>
    )}
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-4">
    <span class="text-xs bg-white/[0.08] text-gray-300 px-2.5 py-1 rounded-full border border-white/[0.12] font-medium">
      {STORE_TYPE_LABELS[store.type]}
    </span>
    {store.stocksPokemonTcg && (
      <span class="text-xs bg-green-500/15 text-green-300 px-2.5 py-1 rounded-full border border-green-500/25 font-medium">
        ✓ Stocks TCG
      </span>
    )}
    {store.hasOnlinePreorders && (
      <span class="text-xs bg-pokeblue-500/15 text-pokeblue-300 px-2.5 py-1 rounded-full border border-pokeblue-500/25 font-medium">
        ✓ Online Orders
      </span>
    )}
  </div>

  <!-- Notes -->
  {store.notes && (
    <p class="text-gray-400 text-sm leading-relaxed mb-4">{store.notes}</p>
  )}

  <!-- Link -->
  <a
    href={store.websiteUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 text-sm font-medium text-pokeblue-300 hover:text-pokeblue-200 transition-colors mt-auto"
  >
    Visit website
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>
