---
import type { PokemonRelease } from "../types/release";
import ConfidenceBadge from "./ConfidenceBadge.astro";
import StatusBadge from "./StatusBadge.astro";
import PredictionBadge from "./PredictionBadge.astro";
import { predictRetailers } from "../utils/predictRetailers";
import { isUpcomingWatchlist } from "../utils/releaseFilters";

interface Props {
  release: PokemonRelease;
}

const { release } = Astro.props;
const predictions = predictRetailers(release);
const topPredictions = predictions.slice(0, 2);

const releaseDate = release.releaseDate
  ? new Date(release.releaseDate).toLocaleDateString("en-AU", {
      timeZone: "Australia/Brisbane",
      day: "numeric",
      month: "short",
      year: "numeric",
    })
  : null;

const now = new Date();
const releaseDateObject = release.releaseDate ? new Date(`${release.releaseDate}T00:00:00`) : null;
const isUpcoming = releaseDateObject ? releaseDateObject >= new Date(now.toISOString().slice(0, 10)) : false;
const isFutureWatchlist = isUpcomingWatchlist(release);

function getStatusLabel() {
  if (release.releaseDate && isUpcoming) {
    if (release.availabilityStatus === "preorder_live") return "Preorder live";
    if (release.availabilityStatus === "preorder_expected") return "Preorder expected";
    return `Releases ${releaseDate}`;
  }

  if (!release.releaseDate) {
    if (release.availabilityStatus === "restock_possible") return "Restock possible";
    if (isFutureWatchlist) return "Future watchlist";
    return "Date TBC";
  }

  if (release.availabilityStatus === "restock_possible") {
    return "Restock possible";
  }

  return `Released ${releaseDate}`;
}

const dateLabel = getStatusLabel();
---

<a
  href={`/releases/${release.id}`}
  class="pocket-card group flex flex-col"
>
  <div class="p-6 flex-1 flex flex-col">
    <!-- Top row: type chip + badges -->
    <div class="flex items-start justify-between gap-3 mb-4">
      <span class="text-xs font-bold text-gray-300 bg-white/[0.1] px-3 py-1.5 rounded-full uppercase tracking-wide">
        {release.productType}
      </span>
      <div class="flex items-center gap-2 flex-wrap justify-end">
        <StatusBadge status={release.availabilityStatus} />
        <ConfidenceBadge confidence={release.confidence} />
      </div>
    </div>

    <!-- Product name -->
    <h3 class="font-display font-bold text-white text-lg leading-snug mb-1 group-hover:text-pokeblue-200 transition-colors">
      {release.name}
    </h3>
    {release.setName && (
      <p class="text-gray-400 text-sm mb-4 font-medium">{release.setName}</p>
    )}

    <!-- Date section with icon -->
    <div class="flex items-center gap-2 mb-6 mt-2">
      <span class="text-lg" aria-hidden="true">📅</span>
      <span class={`text-sm font-semibold ${isUpcoming ? "text-pokeyellow-400" : "text-gray-400"}`}>
        {dateLabel}
      </span>
    </div>

    {topPredictions.length > 0 && (
      <div class="mt-auto mb-4 p-4 rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] border border-white/[0.1]">
        <div class="mb-3 text-xs uppercase tracking-widest font-bold text-gray-400">Where to check</div>
        <div class="space-y-2.5">
          {topPredictions.map((prediction) => (
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="text-sm font-semibold text-white">{prediction.retailerName}</p>
                <p class="text-xs text-gray-400 mt-0.5">{prediction.predictedCheckDay}</p>
              </div>
              <PredictionBadge likelihood={prediction.likelihood} />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Retailers -->
    {release.retailersToCheck.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-auto">
        {release.retailersToCheck.slice(0, 2).map((r) => (
          <span class="text-xs bg-white/[0.08] text-gray-300 px-3 py-1.5 rounded-full border border-white/[0.12] font-medium">
            {r}
          </span>
        ))}
        {release.retailersToCheck.length > 2 && (
          <span class="text-xs text-gray-500 px-2 py-1.5 font-medium">
            +{release.retailersToCheck.length - 2}
          </span>
        )}
      </div>
    )}
  </div>

  <!-- Card footer -->
  <div class="border-t border-white/[0.08] px-6 py-3 flex items-center justify-between bg-gradient-to-r from-white/[0.02] to-transparent">
    <span class="text-xs font-medium text-gray-500">
      {release.region}
    </span>
    <span class="text-xs font-semibold text-pokeblue-400 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
      Details →
    </span>
  </div>
</a>
