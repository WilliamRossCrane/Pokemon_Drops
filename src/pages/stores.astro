---
import BaseLayout from "../layouts/BaseLayout.astro";
import StoreCard from "../components/StoreCard.astro";
import { stores } from "../data/stores.config";
import type { StoreRegion } from "../types/store";
import { REGION_ORDER } from "../types/store";

// Group stores by region in a stable order
const byRegion = REGION_ORDER.map((region) => ({
  region,
  stores: stores.filter((s) => s.region === region),
})).filter((g) => g.stores.length > 0);
---

<BaseLayout
  title="Stores"
  description="Gold Coast, Brisbane, and Australian online stores that stock Pokémon TCG products."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="font-display font-black text-white text-4xl sm:text-5xl mb-3">
        Retailers
      </h1>
      <p class="text-gray-400 text-base max-w-2xl">
        Find Australian stores that stock Pokémon TCG products. From local shops to online retailers, 
        we've curated the best places to get your cards.
      </p>
    </div>

    <!-- Region sections -->
    {byRegion.map(({ region, stores: regionStores }) => (
      <section class="mb-14">
        <div class="mb-6">
          <h2 class="font-display font-bold text-white text-2xl">{region}</h2>
          <span class="inline-block text-xs text-gray-500 mt-1">
            {regionStores.length} {regionStores.length === 1 ? "store" : "stores"}
          </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {regionStores.map((store) => (
            <StoreCard store={store} />
          ))}
        </div>
      </section>
    ))}

    <!-- Add store CTA -->
    <div class="pocket-card p-6">
      <h3 class="font-display font-bold text-white text-lg mb-2">Know a store we're missing?</h3>
      <p class="text-gray-400 text-sm mb-4">
        Edit <code class="text-xs bg-white/[0.08] px-2 py-1 rounded font-mono text-pokeblue-300">src/data/stores.config.ts</code>
        and open a pull request.
      </p>
      <p class="text-xs text-gray-500">See README for contribution instructions.</p>
    </div>

  </div>
</BaseLayout>
