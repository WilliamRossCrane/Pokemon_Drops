---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReleaseCard from "../../components/ReleaseCard.astro";
import StaleDataWarning from "../../components/StaleDataWarning.astro";
import EmptyState from "../../components/EmptyState.astro";
import type { PokemonRelease, ProductType, AvailabilityStatus } from "../../types/release";
import { PRODUCT_TYPES } from "../../types/release";
import releasesData from "../../data/releases.generated.json";
import futureWatchlistData from "../../data/future-watchlist.json";
import { isFutureDatedRelease, isUpcomingWatchlist, isRestockWatch } from "../../utils/releaseFilters";

function mergeReleases(releases: PokemonRelease[], extra: PokemonRelease[]) {
  const seen = new Map<string, PokemonRelease>();
  [...releases, ...extra].forEach((release) => {
    if (!seen.has(release.id)) {
      seen.set(release.id, release);
    }
  });
  return Array.from(seen.values());
}

const generatedReleases: PokemonRelease[] = releasesData.releases as PokemonRelease[];
const futureWatchlist: PokemonRelease[] = futureWatchlistData as PokemonRelease[];
const allReleases: PokemonRelease[] = mergeReleases(generatedReleases, futureWatchlist);
const generatedAt: string = releasesData.generatedAt;

const upcoming = [...allReleases]
  .filter((release) => isFutureDatedRelease(release))
  .sort((a, b) => {
    if (!a.releaseDate) return 1;
    if (!b.releaseDate) return -1;
    return new Date(a.releaseDate).getTime() - new Date(b.releaseDate).getTime();
  });

const upcomingWatchlist = [...allReleases]
  .filter((release) => isUpcomingWatchlist(release))
  .sort((a, b) => {
    const aDate = a.releaseDate ? new Date(a.releaseDate).getTime() : Infinity;
    const bDate = b.releaseDate ? new Date(b.releaseDate).getTime() : Infinity;
    return aDate - bDate;
  });

const watchlist = [...allReleases]
  .filter((release) => !isFutureDatedRelease(release) && isRestockWatch(release))
  .sort((a, b) => {
    if (!a.releaseDate) return 1;
    if (!b.releaseDate) return -1;
    return new Date(a.releaseDate).getTime() - new Date(b.releaseDate).getTime();
  });
---

<BaseLayout
  title="All Releases"
  description="All tracked Pokémon TCG releases and preorders for Australia — ETBs, booster boxes, tins, and more."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="font-display font-black text-white text-3xl sm:text-4xl mb-2">
        All Releases
      </h1>
      <p class="text-gray-400 text-base max-w-2xl">
        Every tracked Pokémon TCG product — upcoming, preorder, released, and possible restocks.
        Filtered and sorted below. Sources always linked.
      </p>
    </div>

    <div class="mb-6">
      <StaleDataWarning generatedAt={generatedAt} />
    </div>

    <!-- Controls row -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs text-gray-600 font-medium">Type:</span>
        <button class="filter-chip filter-chip-active" data-product-filter="all">All</button>
        {PRODUCT_TYPES.map((type) => (
          <button class="filter-chip filter-chip-inactive" data-product-filter={type}>
            {type}
          </button>
        ))}
      </div>
      <button id="toggle-past" class="status-tab px-3 py-1.5 rounded-full text-sm font-medium border bg-surface-card border-white/10 text-gray-400 hover:border-white/20" type="button">
        Show past releases
      </button>
    </div>

    <!-- Status tabs -->
    <div class="flex gap-2 flex-wrap mb-8 border-b border-white/[0.06] pb-4">
      {[
        { label: "Upcoming", value: "upcoming" },
        { label: "Preorder Live", value: "preorder_live" },
        { label: "Restock Possible", value: "restock_possible" },
        { label: "Released", value: "released" },
        { label: "All", value: "all" },
      ].map((tab, i) => (
        <button
          class={`status-tab px-3 py-1.5 rounded-full text-sm font-medium border transition-all duration-150 ${
            i === 0
              ? "bg-pokeblue-600 border-pokeblue-500 text-white"
              : "bg-surface-card border-white/10 text-gray-400 hover:border-white/20"
          }`}
          data-status-tab={tab.value}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Upcoming drops -->
    <section class="mb-10">
      <div class="mb-4">
        <h2 class="font-display font-bold text-white text-xl">Upcoming Drops</h2>
        <p class="text-gray-400 text-sm">Future releases with confirmed dates sorted by soonest arrival.</p>
      </div>
      <div id="releases-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {upcoming.map((release) => (
          <div
            class="release-card-wrapper"
            data-product-type={release.productType}
            data-status={release.availabilityStatus}
            data-release-date={release.releaseDate ?? ""}
          >
            <ReleaseCard release={release} />
          </div>
        ))}
      </div>
    </section>

    {upcomingWatchlist.length > 0 && (
      <section class="mb-10">
        <div class="mb-4">
          <h2 class="font-display font-bold text-white text-xl">Upcoming Watchlist</h2>
          <p class="text-gray-400 text-sm">Announced and expected items without a confirmed date.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {upcomingWatchlist.map((release) => (
            <div
              class="release-card-wrapper"
              data-product-type={release.productType}
              data-status={release.availabilityStatus}
              data-release-date={release.releaseDate ?? ""}
            >
              <ReleaseCard release={release} />
            </div>
          ))}
        </div>
      </section>
    )}

    {watchlist.length > 0 && (
      <section class="mb-10">
        <div class="mb-4">
          <h2 class="font-display font-bold text-white text-xl">Restock / Rerelease Watchlist</h2>
          <p class="text-gray-400 text-sm">Products without a confirmed future date, worth checking as release windows approach.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {watchlist.map((release) => (
            <div
              class="release-card-wrapper"
              data-product-type={release.productType}
              data-status={release.availabilityStatus}
              data-release-date={release.releaseDate ?? ""}
            >
              <ReleaseCard release={release} />
            </div>
          ))}
        </div>
      </section>
    )}

    <div id="empty-state" class="hidden">
      <EmptyState
        message="No releases match those filters"
        hint="Try changing the type or status filter"
      />
    </div>

    <!-- Count -->
    <p id="results-count" class="text-gray-600 text-xs mt-6">
      Showing {upcoming.length + upcomingWatchlist.length + watchlist.length} releases
    </p>
  </div>
</BaseLayout>

<script>
  const productButtons = document.querySelectorAll<HTMLButtonElement>("[data-product-filter]");
  const statusTabs = document.querySelectorAll<HTMLButtonElement>("[data-status-tab]");
  const cards = document.querySelectorAll<HTMLElement>(".release-card-wrapper");
  const emptyState = document.getElementById("empty-state");
  const countEl = document.getElementById("results-count");

  let activeProduct = "all";
  let activeStatus = "upcoming";
  let showPast = false;

  const todayDate = new Date(new Date().toISOString().slice(0, 10));

  function isOldRelease(card: HTMLElement) {
    const dateStr = card.dataset.releaseDate;
    const status = card.dataset.status;
    if (status === "released") return true;
    if (!dateStr) return false;
    return new Date(dateStr) < todayDate;
  }

  function isUpcoming(card: HTMLElement) {
    const dateStr = card.dataset.releaseDate;
    const status = card.dataset.status;
    if (status === "released") return false;
    if (!dateStr) return true; // no date = treat as upcoming/unknown
    return new Date(dateStr) >= todayDate;
  }

  function applyFilters() {
    let count = 0;

    cards.forEach((card) => {
      const productMatch =
        activeProduct === "all" || card.dataset.productType === activeProduct;

      let statusMatch = false;
      if (activeStatus === "all") {
        statusMatch = true;
      } else if (activeStatus === "upcoming") {
        statusMatch = isUpcoming(card);
      } else {
        statusMatch = card.dataset.status === activeStatus;
      }

      const pastMatch = showPast || !isOldRelease(card);
      const show = productMatch && statusMatch && pastMatch;
      card.classList.toggle("hidden", !show);
      if (show) count++;
    });

    emptyState?.classList.toggle("hidden", count > 0);
    if (countEl) countEl.textContent = `Showing ${count} release${count !== 1 ? "s" : ""}`;
  }

  productButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      productButtons.forEach((b) => {
        b.classList.toggle("filter-chip-active", b === btn);
        b.classList.toggle("filter-chip-inactive", b !== btn);
      });
      activeProduct = btn.dataset.productFilter!;
      applyFilters();
    });
  });

  const togglePastButton = document.getElementById("toggle-past");

  statusTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      statusTabs.forEach((t) => {
        t.classList.toggle("bg-pokeblue-600", t === tab);
        t.classList.toggle("border-pokeblue-500", t === tab);
        t.classList.toggle("text-white", t === tab);
        t.classList.toggle("bg-surface-card", t !== tab);
        t.classList.toggle("border-white/10", t !== tab);
        t.classList.toggle("text-gray-400", t !== tab);
      });
      activeStatus = tab.dataset.statusTab!;
      applyFilters();
    });
  });

  togglePastButton?.addEventListener("click", () => {
    showPast = !showPast;
    togglePastButton.textContent = showPast ? "Hide past releases" : "Show past releases";
    applyFilters();
  });

  // Initial render — show upcoming by default
  applyFilters();
</script>
