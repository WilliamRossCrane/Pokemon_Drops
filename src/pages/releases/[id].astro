---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ConfidenceBadge from "../../components/ConfidenceBadge.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import Countdown from "../../components/Countdown.astro";
import RetailerPredictionCard from "../../components/RetailerPredictionCard.astro";
import { predictRetailers } from "../../utils/predictRetailers";
import type { PokemonRelease } from "../../types/release";
import releasesData from "../../data/releases.generated.json";

// Astro static path generation — one page per release
export async function getStaticPaths() {
  const releases: PokemonRelease[] = releasesData.releases as PokemonRelease[];
  return releases.map((r) => ({
    params: { id: r.id },
    props: { release: r },
  }));
}

interface Props {
  release: PokemonRelease;
}

const { release } = Astro.props;
const predictions = predictRetailers(release);

const isUpcoming = release.releaseDate
  ? new Date(release.releaseDate) > new Date()
  : false;

function formatDate(dateStr?: string) {
  if (!dateStr) return "TBC";
  return new Date(dateStr).toLocaleDateString("en-AU", {
    timeZone: "Australia/Brisbane",
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

function formatChecked(dateStr: string) {
  return new Date(dateStr).toLocaleString("en-AU", {
    timeZone: "Australia/Brisbane",
    dateStyle: "medium",
    timeStyle: "short",
  });
}
---

<BaseLayout
  title={release.name}
  description={`${release.productType} — ${release.setName ?? "Pokémon TCG"} — releasing in Australia ${release.releaseDate ? `on ${formatDate(release.releaseDate)}` : "soon"}.`}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">

    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-xs text-gray-600 hover:text-gray-500 transition-colors">
      <a href="/" class="hover:text-gray-400">Home</a>
      <span class="text-gray-700">/</span>
      <a href="/releases" class="hover:text-gray-400">Releases</a>
      <span class="text-gray-700">/</span>
      <span class="text-gray-500 truncate max-w-xs">{release.name}</span>
    </nav>

    <!-- Hero card -->
    <div class="pocket-card p-6 sm:p-8 mb-8">
      <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-6 items-start">
        <div>
          <!-- Badges row -->
          <div class="flex items-center gap-2 flex-wrap mb-4">
            <StatusBadge status={release.availabilityStatus} />
            <ConfidenceBadge confidence={release.confidence} />
          </div>

          <!-- Name -->
          <h1 class="font-display font-black text-white text-3xl sm:text-4xl leading-tight mb-2">
            {release.name}
          </h1>
          {release.setName && (
            <p class="text-gray-400 text-base mb-4">{release.setName}</p>
          )}

          <!-- Meta row -->
          <div class="flex flex-wrap gap-6 text-sm">
            <div>
              <span class="text-gray-600 text-xs block mb-1 uppercase font-bold tracking-wide">Product type</span>
              <span class="text-gray-200 font-medium">{release.productType}</span>
            </div>
            <div>
              <span class="text-gray-600 text-xs block mb-1 uppercase font-bold tracking-wide">Region</span>
              <span class="text-gray-200 font-medium">{release.region}</span>
            </div>
            <div>
              <span class="text-gray-600 text-xs block mb-1 uppercase font-bold tracking-wide">Release date</span>
              <span class={`font-bold ${isUpcoming ? "text-pokeyellow-400" : "text-gray-300"}`}>
                {formatDate(release.releaseDate)}
              </span>
            </div>
            {release.preorderDate && (
              <div>
                <span class="text-gray-600 text-xs block mb-1 uppercase font-bold tracking-wide">Preorder date</span>
                <span class="text-gray-200 font-medium">{formatDate(release.preorderDate)}</span>
              </div>
            )}
          </div>
        </div>

        <!-- Image if available -->
        {release.imageUrl && (
          <img
            src={release.imageUrl}
            alt={release.name}
            loading="lazy"
            class="w-32 sm:w-40 rounded-lg object-contain bg-gradient-to-br from-pokeblue-900/30 to-surface-card p-3 border border-white/[0.1]"
          />
        )}
      </div>

      <!-- Countdown (upcoming only) -->
      {isUpcoming && release.releaseDate && (
        <div class="mt-6 pt-6 border-t border-white/[0.1]">
          <Countdown targetDate={release.releaseDate} label="Releases in" />
        </div>
      )}
    </div>

    <!-- Two column layout -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">

      <!-- Retailers -->
      <div class="pocket-card p-6">
        <h2 class="font-display font-bold text-white text-lg mb-4">
          Retailers to check
        </h2>
        {release.retailersToCheck.length > 0 ? (
          <ul class="space-y-2 mb-4">
            {release.retailersToCheck.map((r) => (
              <li class="flex items-center gap-3 text-sm text-gray-300">
                <span class="w-2 h-2 rounded-full bg-pokeblue-400 flex-shrink-0"></span>
                {r}
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-gray-500 text-sm mb-4">No specific retailers tracked yet.</p>
        )}

        <p class="text-gray-500 text-xs leading-relaxed border-t border-white/[0.08] pt-4">
          Stock is never guaranteed. Check with each retailer directly.
        </p>
      </div>

      <!-- Sources -->
      <div class="pocket-card p-6">
        <h2 class="font-display font-bold text-white text-lg mb-4">
          Source links
        </h2>
        {release.sourceUrls.length > 0 ? (
          <ul class="space-y-2">
            {release.sourceUrls.map((url) => {
              const domain = new URL(url).hostname.replace("www.", "");
              return (
                <li>
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2.5 text-sm text-pokeblue-300 hover:text-pokeblue-200 transition-colors font-medium"
                  >
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    {domain}
                  </a>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="text-gray-500 text-sm">No sources tracked yet for this product.</p>
        )}
      </div>
    </div>

    <!-- Prediction section -->
    {predictions.length > 0 ? (
      <div class="pocket-card p-6 mb-8">
        <h2 class="font-display font-bold text-white text-lg mb-2">
          Where to check based on history
        </h2>
        <p class="text-gray-400 text-sm mb-5 leading-relaxed">
          These suggestions are based on previous release patterns, not confirmed stock.
          Always verify directly with the retailer.
        </p>
        <div class="grid gap-4">
          {predictions.map((prediction) => (
            <RetailerPredictionCard prediction={prediction} />
          ))}
        </div>
      </div>
    ) : (
      <div class="pocket-card p-6 mb-8">
        <h2 class="font-display font-bold text-white text-lg mb-2">
          Prediction data unavailable
        </h2>
        <p class="text-gray-400 text-sm leading-relaxed">
          No matching previous release patterns are stored for this product type yet.
          You can add patterns in <code class="text-xs bg-white/[0.08] px-2 py-1 rounded font-mono text-pokeblue-300">src/data/previous-release-patterns.json</code>.
        </p>
      </div>
    )}

    <!-- Notes section -->
    {release.notes && (
      <div class="pocket-card p-6 mb-8">
        <h2 class="font-display font-bold text-white text-lg mb-3">
          Notes
        </h2>
        <p class="text-gray-400 text-sm leading-relaxed">{release.notes}</p>
      </div>
    )}

    <!-- Confidence explanation -->
    <div class="pocket-card p-6 mb-8">
      <h2 class="font-display font-bold text-white text-lg mb-3">
        Confidence level: <span class="font-display capitalize">{release.confidence}</span>
      </h2>
      <p class="text-gray-400 text-sm leading-relaxed">
        {release.confidence === "high" &&
          "Product and date confirmed by an official Pokémon source or clear retailer listing with an Australian release date."}
        {release.confidence === "medium" &&
          "Product is likely real but Australian availability is inferred from retailer listings or release patterns."}
        {release.confidence === "low" &&
          "Product is rumoured, incomplete, missing dates, or not yet confirmed for Australia."}
      </p>
    </div>

    <!-- Disclaimer -->
    <div class="bg-gradient-to-r from-yellow-500/10 to-yellow-600/5 border border-yellow-500/20 rounded-lg p-5 mb-8">
      <p class="text-yellow-600 text-xs leading-relaxed">
        <strong class="text-yellow-500 block mb-1">⚠ Disclaimer</strong>
        This tracker uses publicly available information. Stock availability is never guaranteed. Release dates and preorder windows can change without notice. Always verify with the retailer directly before travelling or making purchasing decisions.
      </p>
    </div>

    <!-- Meta footer -->
    <div class="flex items-center justify-between mb-6">
      <p class="text-gray-600 text-xs">
        Last checked: {formatChecked(release.lastChecked)} AEST
      </p>
      <a href="/releases" class="inline-flex items-center gap-1.5 text-sm text-pokeblue-400 hover:text-pokeblue-300 transition-colors font-medium">
        ← Back to releases
      </a>
    </div>

  </div>
</BaseLayout>
