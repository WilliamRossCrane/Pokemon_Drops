---
import BaseLayout from "../layouts/BaseLayout.astro";
import ReleaseCard from "../components/ReleaseCard.astro";
import Countdown from "../components/Countdown.astro";
import StaleDataWarning from "../components/StaleDataWarning.astro";
import StatusBadge from "../components/StatusBadge.astro";
import type { PokemonRelease, ProductType, AvailabilityStatus } from "../types/release";
import releasesData from "../data/releases.generated.json";
import futureWatchlistData from "../data/future-watchlist.json";
import { isFutureDatedRelease, isUpcomingWatchlist, isRestockWatch } from "../utils/releaseFilters";

function mergeReleases(releases: PokemonRelease[], extra: PokemonRelease[]) {
  const seen = new Map<string, PokemonRelease>();
  [...releases, ...extra].forEach((release) => {
    if (!seen.has(release.id)) {
      seen.set(release.id, release);
    }
  });
  return Array.from(seen.values());
}

// Pull data from the generated JSON and future watchlist
const generatedReleases: PokemonRelease[] = releasesData.releases as PokemonRelease[];
const futureWatchlist: PokemonRelease[] = futureWatchlistData as PokemonRelease[];
const allReleases: PokemonRelease[] = mergeReleases(generatedReleases, futureWatchlist);
const generatedAt: string = releasesData.generatedAt;

const upcoming = allReleases
  .filter((r) => isFutureDatedRelease(r))
  .sort((a, b) => {
    if (!a.releaseDate) return 1;
    if (!b.releaseDate) return -1;
    const dateSort = new Date(a.releaseDate).getTime() - new Date(b.releaseDate).getTime();
    if (dateSort !== 0) return dateSort;
    const conf: Record<string, number> = { high: 0, medium: 1, low: 2 };
    return conf[a.confidence] - conf[b.confidence];
  });

const upcomingWatchlist = allReleases
  .filter((r) => isUpcomingWatchlist(r))
  .sort((a, b) => {
    const aDate = a.releaseDate ? new Date(a.releaseDate).getTime() : Infinity;
    const bDate = b.releaseDate ? new Date(b.releaseDate).getTime() : Infinity;
    return aDate - bDate;
  });

const watchlist = allReleases
  .filter((r) => !isFutureDatedRelease(r) && isRestockWatch(r))
  .sort((a, b) => {
    if (!a.releaseDate) return 1;
    if (!b.releaseDate) return -1;
    return new Date(a.releaseDate).getTime() - new Date(b.releaseDate).getTime();
  });

const nextDrop = upcoming[0] ?? null;
const featuredReleases = upcoming.slice(0, 6);

// Filter chip config
const filterChips: { label: string; value: string; type: "productType" | "status" }[] = [
  { label: "ETB", value: "Elite Trainer Box", type: "productType" },
  { label: "Booster Box", value: "Booster Box", type: "productType" },
  { label: "Booster Bundle", value: "Booster Bundle", type: "productType" },
  { label: "Collection Box", value: "Collection Box", type: "productType" },
  { label: "Tin", value: "Tin", type: "productType" },
  { label: "Preorder", value: "preorder_live", type: "status" },
  { label: "Restock", value: "restock_possible", type: "status" },
];
---

<BaseLayout title="Home">
  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        
        <!-- Left: Hero content -->
        <div class="max-w-lg">
          <!-- Eyebrow -->
          <div class="inline-flex items-center gap-2 bg-gradient-to-r from-pokeblue-500/20 to-purple-500/20 border border-pokeblue-400/30 rounded-full px-4 py-2 mb-6">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse-slow" aria-hidden="true"></span>
            <span class="text-xs text-gray-200 font-semibold">Gold Coast, QLD</span>
          </div>

          <h1 class="font-display font-black text-5xl sm:text-6xl lg:text-7xl leading-tight mb-6">
            Pokémon<br />
            <span class="gradient-text">TCG Drops</span>
          </h1>

          <p class="text-gray-300 text-lg leading-relaxed mb-10">
            Know what's releasing next on the Gold Coast. Retailers to check, expected dates, and where to find them. Always updated.
          </p>

          <div class="flex items-center gap-3 flex-wrap">
            <a href="/releases" class="btn-primary">Explore releases</a>
            <a href="/stores" class="btn-ghost">Store locator</a>
          </div>
        </div>

        <!-- Right: Featured next drop card -->
        {nextDrop && (
          <div class="relative">
            <div class="pocket-card h-full overflow-hidden flex flex-col">
              <!-- Card top section with gradient -->
              <div class="relative p-6 bg-gradient-to-br from-pokeblue-500/30 to-purple-500/10 border-b border-white/[0.1]">
                <div class="flex items-start justify-between mb-4">
                  <span class="text-xs font-bold text-gray-300 bg-white/[0.1] px-3 py-1 rounded-full uppercase">Next Drop</span>
                  <StatusBadge status={nextDrop.availabilityStatus} />
                </div>
                <h2 class="font-display font-bold text-2xl text-white leading-tight">
                  {nextDrop.name}
                </h2>
                {nextDrop.setName && (
                  <p class="text-gray-400 text-sm mt-2 font-medium">{nextDrop.setName}</p>
                )}
              </div>

              <!-- Card content -->
              <div class="p-6 flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-6">
                  <span class="text-2xl" aria-hidden="true">📅</span>
                  <span class="text-lg font-bold text-pokeyellow-400">
                    {nextDrop.releaseDate
                      ? new Date(nextDrop.releaseDate).toLocaleDateString("en-AU", {
                          timeZone: "Australia/Brisbane",
                          day: "numeric",
                          month: "short",
                          year: "numeric",
                        })
                      : "Date TBC"}
                  </span>
                </div>

                <p class="text-gray-400 text-sm mb-6">
                  {nextDrop.productType} • {nextDrop.region}
                </p>

                <div class="mt-auto">
                  <p class="text-xs text-gray-500 uppercase font-bold mb-3 tracking-wide">Check at:</p>
                  <div class="flex flex-wrap gap-2">
                    {nextDrop.retailersToCheck.slice(0, 3).map((r) => (
                      <span class="text-xs bg-white/[0.08] text-gray-300 px-3 py-1.5 rounded-full font-medium">
                        {r}
                      </span>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Card footer CTA -->
              <div class="border-t border-white/[0.08] px-6 py-4 bg-gradient-to-r from-white/[0.02] to-transparent">
                <a href={`/releases/${nextDrop.id}`} class="text-sm font-semibold text-pokeblue-400 hover:text-pokeblue-300 transition-colors flex items-center gap-2">
                  View details & predictions
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ── Stale data warning ──────────────────────────────────── -->
    <div class="mt-8 mb-10">
      <StaleDataWarning generatedAt={generatedAt} />
    </div>

    <!-- ── Filter chips ───────────────────────────────────────── -->
    <section class="mb-8">
      <p class="text-xs text-gray-500 uppercase font-bold mb-4 tracking-wide">Filter by</p>
      <div class="flex items-center gap-2.5 flex-wrap" role="group" aria-label="Filter releases">
        <button
          class="filter-chip filter-chip-active"
          data-filter="all"
          data-type="all"
        >
          All Types
        </button>
        {filterChips.map((chip) => (
          <button
            class="filter-chip filter-chip-inactive"
            data-filter={chip.value}
            data-type={chip.type}
          >
            {chip.label}
          </button>
        ))}
      </div>
    </section>

    <!-- ── Upcoming drops ────────────────────────────────────── -->
    <section class="mb-16">
      <div class="mb-6">
        <h2 class="font-display font-bold text-white text-2xl mb-2">Upcoming Drops</h2>
        <p class="text-gray-400 text-sm">Confirmed Australian release dates and preorder windows.</p>
      </div>

      <div
        id="releases-grid"
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"
      >
        {upcoming.map((release) => (
          <div
            class="release-card-wrapper"
            data-product-type={release.productType}
            data-status={release.availabilityStatus}
          >
            <ReleaseCard release={release} />
          </div>
        ))}
      </div>
    </section>

    {upcomingWatchlist.length > 0 && (
      <section class="mb-16">
        <div class="mb-6">
          <h2 class="font-display font-bold text-white text-2xl mb-2">Upcoming Watchlist</h2>
          <p class="text-gray-400 text-sm">Announced products waiting for confirmed dates or expected later in 2026.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {upcomingWatchlist.map((release) => (
            <div
              class="release-card-wrapper"
              data-product-type={release.productType}
              data-status={release.availabilityStatus}
            >
              <ReleaseCard release={release} />
            </div>
          ))}
        </div>
      </section>
    )}

    {watchlist.length > 0 && (
      <section class="mb-16">
        <div class="mb-6">
          <h2 class="font-display font-bold text-white text-2xl mb-2">Restock & Rerelease Watchlist</h2>
          <p class="text-gray-400 text-sm">Products worth checking as release windows approach, no confirmed date yet.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {watchlist.map((release) => (
            <div
              class="release-card-wrapper"
              data-product-type={release.productType}
              data-status={release.availabilityStatus}
            >
              <ReleaseCard release={release} />
            </div>
          ))}
        </div>
      </section>
    )}

      <div id="empty-state" class="hidden text-center py-16">
        <div class="text-5xl mb-4" aria-hidden="true">🔍</div>
        <p class="text-gray-400 text-lg mb-2">No releases match that filter.</p>
        <button class="text-pokeblue-400 hover:text-pokeblue-300 text-sm mt-3 font-medium transition-colors" id="clear-filter">
          Clear filters
        </button>
      </div>

      <div class="mt-12 text-center pb-8">
        <p class="text-gray-500 text-sm mb-4">Want to see more?</p>
        <a href="/releases" class="btn-primary">
          View all releases & past drops
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Client-side filter chips logic
  const chips = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
  const cards = document.querySelectorAll<HTMLElement>(".release-card-wrapper");
  const emptyState = document.getElementById("empty-state");

  const todayDate = new Date(new Date().toISOString().slice(0, 10));

  function isUpcoming(card: HTMLElement) {
    const dateStr = card.dataset.releaseDate;
    const status = card.dataset.status;
    if (status === "released") return false;
    if (!dateStr) return true; // no date = treat as announced/preorder/restock watch
    return new Date(dateStr) >= todayDate;
  }

  function applyFilter(filterValue: string, filterType: string) {
    let visibleCount = 0;

    cards.forEach((card) => {
      let show = false;
      if (filterValue === "all") {
        show = true;
      } else if (filterType === "productType") {
        show = card.dataset.productType === filterValue;
      } else if (filterType === "status") {
        show = card.dataset.status === filterValue;
      }
      card.classList.toggle("hidden", !show);
      if (show) visibleCount++;
    });

    emptyState?.classList.toggle("hidden", visibleCount > 0);
  }

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((c) => {
        c.classList.remove("filter-chip-active");
        c.classList.add("filter-chip-inactive");
      });
      chip.classList.add("filter-chip-active");
      chip.classList.remove("filter-chip-inactive");

      applyFilter(chip.dataset.filter!, chip.dataset.type!);
    });
  });

  document.getElementById("clear-filter")?.addEventListener("click", () => {
    chips.forEach((c, i) => {
      c.classList.toggle("filter-chip-active", i === 0);
      c.classList.toggle("filter-chip-inactive", i !== 0);
    });
    applyFilter("all", "all");
  });
</script>
